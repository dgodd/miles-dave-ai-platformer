#!/bin/sh
# post-commit — build release executables after every commit
#
# Installs a release binary into the release/ directory so you can
# grab a ready-to-run build after each commit.
#
# Enable this hook for the whole project:
#   git config core.hooksPath hooks

set -e

PROJECT="platformer"
RELEASE_DIR="$(git rev-parse --show-toplevel)/release"
mkdir -p "$RELEASE_DIR"

# ── Native build (macOS / Linux) ────────────────────────────────────────────
echo "  building release binary for $(uname -s)..."
cargo build --release --quiet 2>&1

# Copy with a platform suffix so macOS and Windows builds coexist in CI.
UNAME_S=$(uname -s)
case "$UNAME_S" in
    Darwin)  SUFFIX="macos"    ;;
    Linux)   SUFFIX="linux"    ;;
    *)       SUFFIX="unknown"  ;;
esac

cp "target/release/$PROJECT" "$RELEASE_DIR/${PROJECT}-${SUFFIX}"
echo "  -> $RELEASE_DIR/${PROJECT}-${SUFFIX}"

# ── Windows cross-compile (optional — requires mingw target) ────────────────
if rustup target list --installed 2>/dev/null | grep -q "x86_64-pc-windows-gnu"; then
    echo "  building release binary for Windows (mingw)..."
    cargo build --release --target x86_64-pc-windows-gnu --quiet 2>&1
    cp "target/x86_64-pc-windows-gnu/release/${PROJECT}.exe" \
       "$RELEASE_DIR/${PROJECT}-windows.exe"
    echo "  -> $RELEASE_DIR/${PROJECT}-windows.exe"
fi

# ── MSVC cross-compile (optional — requires msvc target) ────────────────────
if rustup target list --installed 2>/dev/null | grep -q "x86_64-pc-windows-msvc"; then
    echo "  building release binary for Windows (msvc)..."
    cargo build --release --target x86_64-pc-windows-msvc --quiet 2>&1
    cp "target/x86_64-pc-windows-msvc/release/${PROJECT}.exe" \
       "$RELEASE_DIR/${PROJECT}-windows-msvc.exe"
    echo "  -> $RELEASE_DIR/${PROJECT}-windows-msvc.exe"
fi

echo "  done"
